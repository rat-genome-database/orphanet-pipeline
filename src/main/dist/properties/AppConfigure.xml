<!DOCTYPE beans PUBLIC "-//SPRING//DTD BEAN//EN" "http://www.springframework.org/dtd/spring-beans.dtd">
<beans>
	<bean id="main" class="edu.mcw.rgd.OrphanetPipeline.Manager">
		<property name="version" value="orphanet-pipeline  -- build Jun 22, 2026" />
		<property name="downloader" ref="downloader"/>
		<property name="parser" ref="parser"/>
		<property name="dao" ref="dao"/>
		<property name="useExactMappingsOnly" value="true"/>
	</bean>

	<bean id="downloader" class="edu.mcw.rgd.process.FileDownloader2">
		<property name="externalFile" value="https://www.orphadata.com/data/xml/en_product1.xml"/>
		<property name="localFile" value="data/en_product1.xml"/>
		<property name="prependDateStamp" value="true"/>
		<property name="useCompression" value="true"/>
	</bean>

	<bean id="parser" class="edu.mcw.rgd.OrphanetPipeline.Product1Parser"/>

	<bean id="dao" class="edu.mcw.rgd.OrphanetPipeline.Dao">
		<property name="ontId" value="RDO"/>
		<property name="xrefSource" value="ORDO"/>
	</bean>
</beans>
